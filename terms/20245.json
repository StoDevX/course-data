	{
		"clbid": "0000165711",
		"credits": 1.0,
		"crsid": "0000025615",
		"department": "ENGL",
		"description": [
			"This course explores British literature of three eras, from Wordsworth to Woolf. Students begin with the romantic revolution of the late 18th century, traverse the wide 19th-century span of Queen Victoria's reign, and cross into the modernist era following the cataclysm of World War I. Within each era, students examine a literary manifesto, a revolutionary event, an epic poem, a novel, and the aesthetics of the period. The course emphasizes conversations across eras and striking moments of \"making it new.\" Offered periodically. Prerequisite: WRIT 120 or equivalent."
		],
		"enrolled": 8,
		"gereqs": [
			"ALS-L",
			"WRI",
			"WAC"
		],
		"instructors": [
			"Sean F. Ward"
		],
		"learningmode": "A",
		"level": 200,
		"max": 18,
		"name": "Romantic/Victorian/Modern",
		"number": 228,
		"pn": false,
		"prerequisites": "WRIT 120 or equivalent.",
